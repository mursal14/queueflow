# ============================================================
# QUEUEFLOW ENVIRONMENT VARIABLES
# Copy this file to .env.local for local dev
# Add all values in Vercel → Project → Settings → Environment Variables
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Stripe ───────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...            # sk_test_... for testing
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...   # pk_test_... for testing
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs (from Products → Prices in Stripe dashboard)
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PROFESSIONAL=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# ── Resend (email) ───────────────────────────────────────────
# Sign up free at resend.com — 3,000 emails/month free
RESEND_API_KEY=re_...
EMAIL_FROM=QueueFlow <noreply@yourdomain.com>

# ── Twilio (SMS) — OPTIONAL ──────────────────────────────────
# Sign up at twilio.com — ~$0.0075/SMS + $1/month phone number
# Leave blank to disable SMS (system works fine without it)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...

# ── App URL ──────────────────────────────────────────────────
# Your Vercel deployment URL (no trailing slash)
NEXT_PUBLIC_APP_URL=https://queueflow.vercel.app
